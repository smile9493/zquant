# Rust
/target/
**/*.rs.bk

# Local env / secrets
/.env
/.env.*
!/.env.example

# AI tooling / local state
/.agents/
/.claude/*
!/.claude/agents/
!/.claude/agents/*.md
/.cursor/

# Trellis: keep local state ignored, but commit shared specs
!.trellis/
.trellis/*
!.trellis/spec/
!.trellis/spec/**

# Editor/OS noise
.DS_Store
Thumbs.db
Desktop.ini
*.swp
*.swo
.idea/
.vscode/

# Generated artifacts sometimes created at repo root
/docker-compose.yml
