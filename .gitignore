# Rust
/target/
**/*.rs.bk

# Local env / secrets
/.env
/.env.*
!/.env.example

# AI tooling / local state
/.agents/
/.claude/*
!/.claude/agents/
!/.claude/agents/*.md
/.cursor/
/.kiro/
/.kilocode/

# Trellis: commit shared specs + tasks, ignore local workspace
!.trellis/
.trellis/*
!.trellis/.gitignore
!.trellis/spec/
!.trellis/spec/**
!.trellis/tasks/
!.trellis/tasks/**
.trellis/workspace/

# Editor/OS noise
.DS_Store
Thumbs.db
Desktop.ini
*.swp
*.swo
.idea/
.vscode/

# Generated artifacts sometimes created at repo root
/docker-compose.yml

# Deprecated planning files (now use .trellis/tasks/)
/task_plan.md
/findings.md
/progress.md
